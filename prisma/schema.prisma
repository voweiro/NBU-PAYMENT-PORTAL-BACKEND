generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Fee {
  id           String    @id @default(uuid())
  programId    String?   // Optional: specific to a program
  facultyId    String?   // Optional: specific to a faculty
  departmentId String?   // Optional: specific to a department
  name         String    // e.g., "Acceptance Fee", "Tuition Fee"
  amount       Decimal   @db.Decimal(14, 2)
  currency     String    @default("NGN")
  description  String?
  
  // NEW: Distinguish by Program Level (UG, PG, DIPLOMA)
  programType  String?   // e.g., "UNDERGRADUATE", "POSTGRADUATE"
  
  levels       Json?     // ["L100", "L200"] or "ALL"
  semester     String?   // "FIRST", "SECOND", "ALL"
  sessionId    String?   
  programLevelId String?   // NEW: Link to Academic Service ProgramLevel
  
  hostelType   String?   
  type         FeeType?
  
  mandatory    Boolean   @default(true)
  payments     Payment[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}


model Payment {
  id                String        @id @default(uuid())
  reference         String        @unique
  amount            Decimal       @db.Decimal(14, 2)
  status            PaymentStatus @default(PENDING)
  
  // USER IDENTIFICATION
  userId            String        // Global Auth UUID (always present)
  payerType         PayerType     // NEW: Tells us if they were an APPLICANT or STUDENT at time of payment
  
  // SNAPSHOT FIELDS (Populated based on availability)
  studentName       String?
  studentEmail      String?
  matricNumber      String?       // Null for applicants
  jambNumber        String?       // Null for PG or non-JAMB programs
  applicantId       String?       
  applicationId     String?       // The primary link for admission tracking
  
  // ACADEMIC CONTEXT
  programId         String? 
  sessionId         String? 
  programLevelId    String?       // NEW: Link to Academic Service ProgramLevel
  level             String?       // e.g., "L100"
  semester          String?
  phoneNumber       String?
  address           String?
  
  // FEE RELATION
  feeId             String
  fee               Fee           @relation(fields: [feeId], references: [id])
  items             Json?         
  
  // TRACKING
  channel           String?       // PAYSTACK, etc.
  percentagePaid    Decimal?      @db.Decimal(5, 2)
  balanceDue        Decimal?      @db.Decimal(14, 2)
  originalReference String?       
  
  metadata          Json?         
  proofUrl          String?       // For manual uploads
  verifiedBy        String?       
  verifiedAt        DateTime? 
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

enum PayerType {
  APPLICANT
  STUDENT
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  ABANDONED
  VERIFYING
}

enum FeeType {
  APPLICATION_FORM
  TUITION
  ACCEPTANCE
  HOSTEL
  OTHER
}

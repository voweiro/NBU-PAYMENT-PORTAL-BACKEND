DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"
PORT=4000

# Payments (set one or both depending on gateway used)
PAYSTACK_SECRET_KEY="sk_test_xxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK-xxx"

# Google Drive API
GOOGLE_DRIVE_CLIENT_ID=""
GOOGLE_DRIVE_CLIENT_SECRET=""
GOOGLE_DRIVE_REFRESH_TOKEN=""
GOOGLE_DRIVE_PARENT_FOLDER="" # Optional: parent folder ID to upload receipts

# Email / Nodemailer
# Set EMAIL_SERVICE to 'gmail' when using Gmail (recommended with App Password)
EMAIL_SERVICE="gmail"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM=""
EMAIL_SKIP_VERIFY=true
EMAIL_CONNECTION_TIMEOUT=8000
EMAIL_GREETING_TIMEOUT=8000
EMAIL_SOCKET_TIMEOUT=10000
EMAIL_POOL=true

# HTTP email provider (Resend) — recommended on hosts where SMTP may be blocked
RESEND_API_KEY=""
EMAIL_HTTP_TIMEOUT=10000

# Admin auth
JWT_SECRET="change_me"